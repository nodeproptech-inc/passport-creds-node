# PostgreSQL connection string
DATABASE_URL=postgresql://passport:passport@localhost:5432/passportcreds

# Port the NestJS server listens on
PORT=3001

# Shared secret that the AI Attester webhook must include (X-Webhook-Secret header)
WEBHOOK_SECRET=change-me-in-production

# Set to "true" to use the mock contract adapter (no real onchain writes)
DEMO_MODE=true

# Onchain contract addresses (from contracts/deployments.json)
CLAIM_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
COMPLIANCE_PASSPORT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
ACCESS_GATE_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# RPC URL for the network where contracts are deployed
RPC_URL=http://localhost:8545

# Private key for the CRE_UPDATER_ROLE wallet (used only by ContractAdapter in live mode)
CRE_UPDATER_PRIVATE_KEY=0x

# CRE base URL — where this backend sends trigger requests
CRE_BASE_URL=http://localhost:3002

# Tenant / product branding label (shown in responses)
TENANT_ID=passportcreds-demo
