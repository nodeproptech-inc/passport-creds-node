# Private key of the deployer wallet (no 0x prefix needed by forge, but include it)
DEPLOYER_PRIVATE_KEY=0x

# Wallet address that the CRE node operator will use to submit claims
CRE_UPDATER_ADDRESS=0x

# RPC endpoint for the target network
# Local: http://localhost:8545
# Sepolia: https://sepolia.infura.io/v3/<key>
# Arbitrum Sepolia: https://arbitrum-sepolia.infura.io/v3/<key>
RPC_URL=http://localhost:8545

# Etherscan / Blockscout API key for contract verification (optional for local)
ETHERSCAN_API_KEY=
